{
    "extends": "@tala-tools/tsconfig/base.json",
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "exclude": ["node_modules"]
}
