{
    "name": "@tala-tools/tsdown",
    "version": "0.1.3",
    "private": false,
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/saoudi-h/tala-tools.git",
        "directory": "packages/tsdown"
    },
    "dependencies": {
        "publint": "0.3.21",
        "unplugin-unused": "0.5.7"
    },
    "peerDependencies": {
        "tsdown": "0.21.7"
    },
    "scripts": {
        "build": "tsdown --config-loader unrun",
        "lint": "pnpm exec eslint . --max-warnings 0",
        "lint:fix": "pnpm exec eslint . --max-warnings 0 --fix",
        "format:check": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --write",
        "clean": "rimraf node_modules",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "pre-commit": "lint-staged"
    },
    "devDependencies": {
        "@tala-tools/eslint": "workspace:*",
        "@tala-tools/prettier": "workspace:*",
        "@tala-tools/tsconfig": "workspace:*",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.1"
    },
    "types": "./dist/index.d.mts",
    "files": [
        "dist",
        "src"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./configs": {
            "types": "./dist/configs/index.d.mts",
            "default": "./dist/configs/index.mjs"
        },
        "./package.json": "./package.json"
    }
}
