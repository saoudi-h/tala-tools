{
    "name": "@tala-tools/eslint",
    "version": "0.1.0",
    "private": false,
    "description": "Shared ESLint configurations for Tala projects",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hakim/tala-tools.git",
        "directory": "packages/eslint"
    },
    "keywords": [
        "eslint",
        "config",
        "tala"
    ],
    "author": {
        "name": "Saoudi Hakim",
        "url": "https://hakimsaoudi.dev",
        "email": "saoudihakim@gmail.com"
    },
    "license": "MIT",
    "type": "module",
    "types": "./dist/index.d.mts",
    "files": [
        "dist",
        "src"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "clean": "rm -rf *.tsbuildinfo node_modules .turbo dist",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --list-different --write",
        "typecheck": "tsc --noEmit",
        "pre-commit": "lint-staged"
    },
    "devDependencies": {
        "@tala-tools/prettier": "workspace:*",
        "@tala-tools/tsconfig": "workspace:*",
        "@types/eslint-config-prettier": "^6.11.3",
        "@types/eslint-plugin-jsx-a11y": "^6.10.1",
        "@types/node": "^25.6.0"
    },
    "dependencies": {
        "@eslint/config-helpers": "^0.5.0",
        "@eslint/js": "^10.0.1",
        "@next/eslint-plugin-next": "^16.2.3",
        "@typescript-eslint/utils": "^8.58.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-better-tailwindcss": "^4.4.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-playwright": "^2.10.1",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-regexp": "^3.1.0",
        "eslint-plugin-storybook": "^10.3.5",
        "eslint-plugin-tailwindcss": "^3.18.2",
        "eslint-plugin-turbo": "^2.9.6",
        "globals": "^17.5.0",
        "typescript-eslint": "^8.58.1"
    },
    "peerDependencies": {
        "eslint": "^10.2.0",
        "tailwindcss": "^4.2.2"
    },
    "peerDependenciesMeta": {
        "eslint": {
            "optional": false
        },
        "tailwindcss": {
            "optional": true
        }
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./package.json": "./package.json"
    }
}
