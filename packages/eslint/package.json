{
    "name": "@tala-tools/eslint",
    "version": "0.0.1",
    "private": false,
    "description": "Shared ESLint configurations for Tala projects",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hakim/tala-tools.git",
        "directory": "packages/eslint"
    },
    "keywords": [
        "eslint",
        "config",
        "tala"
    ],
    "author": {
        "name": "Saoudi Hakim",
        "url": "https://hakimsaoudi.dev",
        "email": "saoudihakim@gmail.com"
    },
    "license": "MIT",
    "type": "module",
    "types": "./dist/index.d.mts",
    "exports": {
        ".": "./dist/index.mjs",
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "clean": "rm -rf *.tsbuildinfo node_modules .turbo dist",
        "lint": "eslint . --max-warnings 0",
        "lint:fix": "eslint . --fix",
        "format": "prettier \"**/*\" --ignore-unknown --list-different",
        "format:fix": "prettier \"**/*\" --ignore-unknown --list-different --write",
        "typecheck": "tsc --noEmit",
        "pre-commit": "lint-staged"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@next/eslint-plugin-next": "^16.2.3",
